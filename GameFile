class snake {
private:
    string nickname;
    string email;
    string username;
    string password;
    float age;
    int heart;
    int points;
    char body[50];
    int positionX,
        positionY;
public:
    snake(string n, string e, string u, string p, float a, int H, int P, char B, int Y, int X)
    {
        age = a;
        nickname = n;
        username = u;
        password = p;
        email = e;
        heart = H;
        points = P;
        body[0] = B;
        positionY = Y;
        positionX = X;
    }
    ~snake()
    {

    }
    void end() {
        system("cls");
        cout << "\n\n\n";
        cout << "____    _    __  __ _____    _____     _______ ____" << endl;
        cout << "/ ___|  / \\  |  \\/  | ____|  / _ \\ \\   / / ____|  _ \\" << endl;
        cout << "| |  _  / _ \\ | |\\/| |  _|   | | | \\ \\ / /|  _| | |_) |" << endl;
        cout << "| |_| |/ ___ \\| |  | | |___  | |_| |\\ V / | |___|  _ <" << endl;
        cout << " \\____/_/   \\_\\_|  |_|_____|  \\___/  \\_/  |_____|_| \\_\\" << endl;
        cout << "\n\n\n";
    }

    void moveUp() {
        positionY--;
    }
    void moveDown() {
        positionY++;
    }
    void moveRight() {
        positionX++;
    }
    void moveLeft() {
        positionX--;
    }
    int printP() {
        return points;

    }
    int  heartP() {
        return heart;

    }

    int heartM() {
        return heart--;
    }
    int heartA() {
        return heart++;
    }
    int pointA() {
        return points++;
    }
    int pointM() {
        return points--;
    }
    int newHeart() {
        if (points >= 5) {
            points = 0;
            return heart++;
        }
        return heart;
    }

    int getX() { return positionX; }
    int getY() { return positionY; }
};
