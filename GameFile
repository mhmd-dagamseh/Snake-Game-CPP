void GameLoop()
{
    x = 25, y = 12;
    updateAndDraw();

    while (true)
    {

        if (_kbhit()) {
            char input = _getch();
            if (input == 27)
            {
                break;
            }
            else if (Player->heartP() <= 0) {
                Player->end();
                break;
            }
            else if (input == 'w' || input == 'W') {
                Player->moveUp();
            }
            else if (input == 's' || input == 'S') {
                Player->moveDown();
            }
            else if (input == 'a' || input == 'A') {
                Player->moveLeft();
            }
            else if (input == 'd' || input == 'D') {
                Player->moveRight();
            }
            updateAndDraw();
        }

    }

}
